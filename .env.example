# ============================================================================
# BPC DASHBOARD - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file with real credentials to version control!
# ============================================================================

# ============================================================================
# AIRTABLE CONFIGURATION (Financial Data)
# ============================================================================
# Get these from: Airtable → Account → Generate Personal Access Token
AIRTABLE_PAT=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here

# ============================================================================
# SUPABASE CONFIGURATION (Authentication & User Management)
# ============================================================================
# Get these values from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ============================================================================
# SMTP CONFIGURATION (Optional - For Login Email Notifications)
# ============================================================================
# If you want to send actual email notifications for logins, configure SMTP
# Otherwise, emails will be logged to console only
#
# Option 1: Use the same SMTP as Supabase (recommended)
# - Check Supabase Dashboard → Authentication → Email Templates → SMTP Settings
#
# Option 2: Use Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_FROM_EMAIL=noreply@bpc2dashboard.com
#
# Option 3: Use custom SMTP provider
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM_EMAIL=noreply@yourdomain.com

# ============================================================================
# NOTES
# ============================================================================
# SUPABASE_URL: Your Supabase project URL (e.g., https://xxxxx.supabase.co)
# SUPABASE_ANON_KEY: Public anonymous key (safe to expose in frontend)
# SUPABASE_SERVICE_KEY: Service role key (NEVER expose in frontend!)
#   - Use ONLY for admin operations like creating users
#   - Has full database access, bypasses Row-Level Security
#   - Keep this secret secure!
#
# SMTP Settings: Used for login notification emails
#   - If not configured, emails will be logged to console instead of sent
#   - Use same SMTP as your Supabase email configuration for consistency
#   - For Gmail: Generate app-specific password (don't use your main password)

